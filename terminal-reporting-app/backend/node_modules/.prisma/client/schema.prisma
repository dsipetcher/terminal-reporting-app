datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

// ============================================
// СКЛАДЫ И ХРАНЕНИЕ
// ============================================

model Warehouse {
  id            Int     @id @default(autoincrement())
  number        String  @unique
  name          String?
  capacity      Float
  warehouseType String  @default("COAL_YARD") // COAL_YARD, OIL_TANK, COVERED, OPEN_YARD
  zone          String?

  wagons     Wagon[]
  containers Container[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// ЖЕЛЕЗНОДОРОЖНЫЙ ТРАНСПОРТ
// ============================================

model TrainConsist {
  id          Int       @id @default(autoincrement())
  trainNumber String
  origin      String?
  destination String?
  track       String?
  direction   String    @default("INBOUND") // INBOUND, OUTBOUND
  arrivalAt   DateTime
  formedAt    DateTime?
  departureAt DateTime?
  status      String    @default("EN_ROUTE") // EN_ROUTE, ARRIVED, UNLOADING, IN_PARK, FORMING, DEPARTED

  wagons Wagon[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Wagon {
  id          Int     @id @default(autoincrement())
  number      String  @unique
  wagonType   String // PLATFORM, GONDOLA, BOXCAR, TANK, REFRIGERATOR
  cargo       String?
  cargoWeight Float?

  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
  warehouseId Int?

  track       String?
  trainNumber String?
  arrivalAt   DateTime
  departureAt DateTime?

  status String @default("EN_ROUTE") // mirrors TrainConsist status while active

  trainConsist   TrainConsist? @relation(fields: [trainConsistId], references: [id])
  trainConsistId Int?

  container   Container? @relation(fields: [containerId], references: [id])
  containerId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// МОРСКОЙ ТРАНСПОРТ
// ============================================

model Vessel {
  id           Int     @id @default(autoincrement())
  name         String
  imoNumber    String  @unique
  vesselType   String // CONTAINER, BULK_CARRIER, TANKER, RORO, GENERAL_CARGO, OTHER
  grossTonnage Float?
  deadweight   Float?
  length       Float?
  beam         Float?
  draft        Float?
  flag         String?
  owner        String?

  vesselCalls VesselCall[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VesselCall {
  id       Int    @id @default(autoincrement())
  vessel   Vessel @relation(fields: [vesselId], references: [id])
  vesselId Int

  voyageNumber String

  eta DateTime // Expected Time of Arrival
  etd DateTime? // Expected Time of Departure
  ata DateTime? // Actual Time of Arrival
  atd DateTime? // Actual Time of Departure

  berth   Berth? @relation(fields: [berthId], references: [id])
  berthId Int?

  status String @default("EN_ROUTE") // EN_ROUTE, ARRIVED, UNLOADING, DEPARTED, CANCELLED

  agent   String?
  purpose String?

  containers      Container[]
  logisticsOrders LogisticsOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// ПРИЧАЛЫ
// ============================================

model Berth {
  id            Int     @id @default(autoincrement())
  number        String  @unique
  name          String?
  berthType     String // CONTAINER, BULK, LIQUID, RORO, GENERAL, MULTI_PURPOSE
  length        Float
  depth         Float
  maxDeadweight Float?

  isActive Boolean @default(true)

  vesselCalls VesselCall[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// ПАРТИИ ГРУЗА (уголь, нефть) — учётная единица ИЛС
// ============================================

model Container {
  id              Int    @id @default(autoincrement())
  containerNumber String @unique // номер партии груза (batch)
  containerType   String // COAL_ANTHRACITE, COAL_COKING, OIL_CRUDE, OIL_FUEL, PETROLEUM

  status        String // ON_LAND, IN_STORAGE, LOADING_BERTH, ON_VESSEL, AT_DESTINATION_PORT, DELIVERED
  cargoCategory String  @default("COAL") // COAL, OIL, PETROLEUM
  supplierName  String?
  quantityTons  Float?
  quantityUnit  String  @default("TON")

  cargoDescription String?
  grossWeight      Float?
  sealNumber       String?

  vesselCall   VesselCall? @relation(fields: [vesselCallId], references: [id])
  vesselCallId Int?

  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
  warehouseId Int?

  location String?

  wagons        Wagon[]
  materialFlows MaterialFlow[]

  portOfLoading   String?
  portOfDischarge String?
  blNumber        String? // Bill of Lading number

  customsStatus String?

  logisticsOrder   LogisticsOrder? @relation(fields: [logisticsOrderId], references: [id])
  logisticsOrderId Int?
  routeTrackings   CargoTracking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// ПОЛЬЗОВАТЕЛИ И АВТОРИЗАЦИЯ
// ============================================

model User {
  id           Int             @id @default(autoincrement())
  username     String          @unique
  passwordHash String
  fullName     String?
  department   String?
  role         String          @default("USER") // ADMIN, PLANNER, DISPATCHER, WAREHOUSE, USER
  infoEvents   InfoFlowEvent[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

// ============================================
// ИЛС: ОБЕСПЕЧИВАЮЩАЯ ПОДСИСТЕМА (справочники)
// ============================================

model Counterparty {
  id          Int              @id @default(autoincrement())
  code        String           @unique
  name        String
  partnerType String // CLIENT, CARRIER, AGENT, CUSTOMS, RAILWAY
  inn         String?
  contact     String?
  orders      LogisticsOrder[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model PortDirectory {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  country   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CargoDirectory {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  category  String // CONTAINERIZED, BULK, GENERAL, LIQUID, DANGEROUS
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// ИЛС: ФУНКЦИОНАЛЬНАЯ ПОДСИСТЕМА
// ============================================

model LogisticsOrder {
  id               Int                      @id @default(autoincrement())
  orderNumber      String                   @unique
  orderType        String // EXPORT_BULK, STORAGE, SHIP_LOADING
  managementLevel  String // PLANNING, DISPATCH, OPERATIONAL
  status           String                   @default("DRAFT") // DRAFT, PLANNED, IN_PROGRESS, COMPLETED, CANCELLED
  counterparty     Counterparty?            @relation(fields: [counterpartyId], references: [id])
  counterpartyId   Int?
  cargoDescription String?
  cargoWeight      Float?
  origin           String? // поставщик / регион
  destination      String? // порт назначения судна
  supplierName     String?
  plannedStart     DateTime?
  plannedEnd       DateTime?
  actualStart      DateTime?
  actualEnd        DateTime?
  vesselCall       VesselCall?              @relation(fields: [vesselCallId], references: [id])
  vesselCallId     Int?
  notes            String?
  containers       Container[]
  materialFlows    MaterialFlow[]
  infoEvents       InfoFlowEvent[]
  routes           LogisticsRoute[]
  documents        LogisticsOrderDocument[]
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
}

// Документ, прикреплённый к логистическому заказу
model LogisticsOrderDocument {
  id           Int            @id @default(autoincrement())
  order        LogisticsOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId      Int
  fileName     String
  storedName   String
  mimeType     String?
  fileSize     Int
  documentType String? // CONTRACT, INVOICE, WAYBILL, CERTIFICATE, CUSTOMS, OTHER
  description  String?
  uploadedAt   DateTime       @default(now())
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

// Логистический маршрут доставки груза
model LogisticsRoute {
  id          Int             @id @default(autoincrement())
  routeNumber String          @unique
  name        String?
  order       LogisticsOrder? @relation(fields: [orderId], references: [id])
  orderId     Int?
  origin      String
  destination String // порт назначения груза
  routeKind   String          @default("EXPORT") // EXPORT: поставщик → ж/д → склад → судно → порт
  status      String          @default("PLANNED") // PLANNED, ACTIVE, COMPLETED, CANCELLED
  stages      RouteStage[]
  trackings   CargoTracking[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

// Этап (точка) логистического маршрута
model RouteStage {
  id            Int             @id @default(autoincrement())
  route         LogisticsRoute  @relation(fields: [routeId], references: [id], onDelete: Cascade)
  routeId       Int
  sequence      Int
  stageType     String // SUPPLIER, RAIL_STATION, WAREHOUSE, BERTH, SHIP, PORT
  locationCode  String
  locationName  String
  transportMode String? // SEA, RAIL, WAREHOUSE
  plannedAt     DateTime?
  actualAt      DateTime?
  status        String          @default("PENDING") // PENDING, CURRENT, COMPLETED, SKIPPED
  trackingsHere CargoTracking[] @relation("CurrentStage")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([routeId, sequence])
}

// Отслеживание партии груза на маршруте
model CargoTracking {
  id             Int                  @id @default(autoincrement())
  container      Container            @relation(fields: [containerId], references: [id])
  containerId    Int
  route          LogisticsRoute       @relation(fields: [routeId], references: [id], onDelete: Cascade)
  routeId        Int
  currentStage   RouteStage?          @relation("CurrentStage", fields: [currentStageId], references: [id])
  currentStageId Int?
  status         String               @default("REGISTERED") // REGISTERED, IN_TRANSIT, AT_STAGE, DELIVERED, DELAYED
  lastEventAt    DateTime             @default(now())
  notes          String?
  events         CargoTrackingEvent[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([containerId, routeId])
}

// История перемещения груза по этапам маршрута
model CargoTrackingEvent {
  id          Int           @id @default(autoincrement())
  tracking    CargoTracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)
  trackingId  Int
  fromStageId Int?
  toStageId   Int?
  eventAt     DateTime      @default(now())
  description String?
  createdAt   DateTime      @default(now())
}

model MaterialFlow {
  id            Int             @id @default(autoincrement())
  order         LogisticsOrder? @relation(fields: [orderId], references: [id])
  orderId       Int?
  flowType      String // ARRIVAL, DEPARTURE, INTERNAL_TRANSFER, STORAGE
  transportMode String // SEA, RAIL, WAREHOUSE
  quantity      Float?
  unit          String? // TON, M3
  fromLocation  String?
  toLocation    String?
  container     Container?      @relation(fields: [containerId], references: [id])
  containerId   Int?
  performedAt   DateTime        @default(now())
  description   String?
  createdAt     DateTime        @default(now())
}

model InfoFlowEvent {
  id          Int             @id @default(autoincrement())
  ilsFunction String // PLANNING, REGULATION, CONTROL, ANALYSIS, ACCOUNTING
  eventType   String // CREATE, UPDATE, STATUS_CHANGE, ALERT, REPORT
  entityType  String
  entityId    Int?
  message     String
  order       LogisticsOrder? @relation(fields: [orderId], references: [id])
  orderId     Int?
  user        User?           @relation(fields: [userId], references: [id])
  userId      Int?
  createdAt   DateTime        @default(now())
}
